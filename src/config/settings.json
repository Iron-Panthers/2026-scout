{
  "notifications": {
    "title": "Notifications",
    "description": "Configure how you receive notifications",
    "fields": [
      {
        "id": "match-notifications",
        "label": "Match Assignments",
        "description": "Get notified when you're assigned to a match",
        "type": "switch",
        "defaultValue": false
      },
      {
        "id": "reminder-notifications",
        "label": "Match Reminders",
        "description": "Receive reminders before your scheduled matches",
        "type": "switch",
        "defaultValue": false
      }
    ]
  },
  "appearance": {
    "title": "Appearance",
    "description": "Customize how the app looks and feels",
    "fields": [
      {
        "id": "theme",
        "label": "Theme",
        "description": "Choose your preferred color theme",
        "type": "select",
        "options": [
          { "value": "dark", "label": "Dark" },
          { "value": "light", "label": "Light" },
          { "value": "ben", "label": "Ben Mode" }
        ],
        "defaultValue": "dark",
        "editable": true
      }
    ]
  },
  "event": {
    "title": "Event",
    "description": "Current competition event settings",
    "fields": [
      {
        "id": "active-event-code",
        "label": "Active Event Code",
        "description": "Set automatically from the active event",
        "type": "text",
        "defaultValue": "",
        "editable": false
      }
    ]
  },
  "keybinds": {
    "title": "Keybinds",
    "description": "Keyboard shortcuts for quantitative scouting (click a key to rebind)",
    "fields": [
      { "id": "kb-add1", "label": "+1 Shots", "type": "keybind", "defaultValue": "z" },
      { "id": "kb-add5", "label": "+5 Shots", "type": "keybind", "defaultValue": "x" },
      { "id": "kb-add20", "label": "+20 Shots", "type": "keybind", "defaultValue": "c" }
    ]
  }
}
